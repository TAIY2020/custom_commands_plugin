{
  "manifest_version": 2,
  "version": "2.5.1",
  "name": "自定义命令插件 | CustomCommands Plugin",
  "description": "一个允许你通过聊天命令动态添加、删除、列出和触发自定义回复的强大插件，支持群组数据隔离与自定义分组映射。",
  "author": {
    "name": "TaiYang",
    "url": "https://github.com/TAIY2020"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/TAIY2020/custom_commands_plugin",
    "homepage": "https://github.com/TAIY2020/custom_commands_plugin",
    "documentation": "https://github.com/TAIY2020/custom_commands_plugin",
    "issues": "https://github.com/TAIY2020/custom_commands_plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "send.image",
    "config.get",
    "api.call",
    "component.reload_plugin"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "plugin_type": "tool",
  "display": {
    "icon": {
      "type": "local",
      "value": "./assets/icon.svg"
    }
  },
  "id": "TAIY2020.custom-commands-plugin"
}
